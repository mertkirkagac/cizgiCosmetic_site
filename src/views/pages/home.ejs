<%- include('../partials/head') %>
<%- include('../partials/header') %>

<!-- ======= HERO ======= -->
<section class="hero" id="hero">
  <div class="hero-glow" aria-hidden="true"></div>

  <div class="container hero-inner">
    <div class="hero-copy">
      <p class="hero-kicker">Balıkesir · Aerosol Üretim Tesisi</p>
      <h1>
        Markanızın gücü,<br>
        <em>her püskürtmede</em><br>
        hissedilir.
      </h1>
      <p class="hero-lead">
        Kişisel bakımdan teknik aerosollere; formülasyon, dolum ve ambalajlamayı
        tek çatı altında toplayan fason üretim ortağınız.
      </p>
      <div class="hero-actions">
        <a href="/urunler" class="btn btn-primary">Ürün Gruplarımız</a>
        <a href="/iletisim" class="btn btn-ghost">Fason Üretim Teklifi</a>
      </div>
    </div>

    <div class="hero-can">
      <img
        src="/img/hero/branded-spray-hero.png"
        alt="Çizgi Cosmetic logolu aerosol sprey ürünü ve fışkırma efekti"
        class="hero-product-img"
        loading="eager"
        decoding="async"
      >
    </div>
  </div>

  <a href="#tanitim" class="scroll-badge" aria-label="İçeriğe in">
    <svg viewBox="0 0 100 100" aria-hidden="true">
      <defs>
        <path id="scrollCircle" d="M50,50 m-38,0 a38,38 0 1,1 76,0 a38,38 0 1,1 -76,0"/>
      </defs>
      <text>
        <textPath href="#scrollCircle" textLength="238" lengthAdjust="spacing">KEŞFEDİN&#160;•&#160;AŞAĞI&#160;KAYDIRIN&#160;•&#160;</textPath>
      </text>
    </svg>
    <span class="scroll-badge-arrow" aria-hidden="true">↓</span>
  </a>
</section>

<!-- ======= KAYAN ŞERİT ======= -->
<div class="marquee" aria-hidden="true">
  <div class="marquee-track">
    <% const items = ['Deodorant', 'Saç Spreyi', 'Oda Parfümü', 'Teknik Aerosol', 'İnsektisit', 'Mobilya Cilası', 'Kuru Şampuan', 'Private Label']; %>
    <% for (let r = 0; r < 2; r++) { %>
      <% items.forEach(i => { %><span><%= i %></span><i>◦</i><% }) %>
    <% } %>
  </div>
</div>

<!-- ======= TANITIM ======= -->
<section class="section" id="tanitim">
  <div class="container split">
    <div class="split-label">
      <span class="section-no">01</span>
      <h2>Neden<br>Çizgi Cosmetic?</h2>
      <figure class="media-frame">
        <img src="/img/photos/uretim-muhendis.jpg" alt="Üretim hattında kalite kontrolü yapan mühendis" loading="lazy">
      </figure>
    </div>
    <div class="split-body">
      <p class="lede">
        Balıkesir'deki modern tesisimizde, ham maddeden bitmiş ürüne kadar tüm aerosol
        üretim sürecini kendi bünyemizde yönetiyoruz. Formül sizden ya da bizden —
        sonuç her zaman aynı çizgide: <strong>tutarlı, güvenli ve ölçeklenebilir üretim.</strong>
      </p>
      <div class="stats">
        <div class="stat reveal"><b data-count="25">0</b><span>Milyon adet / yıl<br>dolum kapasitesi</span></div>
        <div class="stat reveal"><b data-count="120">0</b><span>Aktif formülasyon<br>portföyü</span></div>
        <div class="stat reveal"><b data-count="14">0</b><span>İhracat yapılan<br>ülke</span></div>
        <div class="stat reveal"><b data-count="48">0</b><span>Saat içinde<br>numune üretimi</span></div>
      </div>
    </div>
  </div>
</section>

<!-- ======= HİZMETLER ======= -->
<section class="section section-dark">
  <div class="container">
    <div class="section-head">
      <span class="section-no">02</span>
      <h2>Tek çatı altında dört hizmet</h2>
    </div>
    <div class="cards-4">
      <% services.forEach((s, i) => { %>
      <article class="service-card reveal" style="--d:<%= i * 90 %>ms">
        <span class="service-index">0<%= i + 1 %></span>
        <h3><%= s.title %></h3>
        <p><%= s.text %></p>
      </article>
      <% }) %>
    </div>
  </div>
</section>

<!-- ======= FOTOĞRAF BANDI ======= -->
<section class="photo-band" style="background-image: url('/img/photos/arge-cizim.jpg')" aria-label="AR-GE çalışması">
  <div class="container">
    <p class="hero-kicker">AR-GE Laboratuvarı</p>
    <h3>Brif'ten laboratuvar numunesine: 48 saat.</h3>
  </div>
</section>

<!-- ======= ÜRÜN GRUPLARI ======= -->
<section class="section">
  <div class="container">
    <div class="section-head section-head-row">
      <div>
        <span class="section-no">03</span>
        <h2>Ürün grupları</h2>
      </div>
      <a href="/urunler" class="btn btn-outline">Tümünü İncele</a>
    </div>
    <div class="cat-list">
      <% categories.forEach((c, i) => { %>
      <a href="/urunler/<%= c.slug %>" class="cat-row reveal" style="--d:<%= i * 70 %>ms">
        <span class="cat-no">0<%= i + 1 %></span>
        <span class="cat-name"><%= c.name %></span>
        <span class="cat-short"><%= c.short %></span>
        <span class="cat-arrow" aria-hidden="true">→</span>
      </a>
      <% }) %>
    </div>
  </div>
</section>

<!-- ======= SÜREÇ ======= -->
<section class="section section-tint">
  <div class="container">
    <div class="section-head">
      <span class="section-no">04</span>
      <h2>Fikirden rafa dört adım</h2>
    </div>
    <ol class="steps">
      <li class="reveal"><b>Brif & Numune</b><p>İhtiyacınızı dinliyor, 48 saat içinde laboratuvar numunesi hazırlıyoruz.</p></li>
      <li class="reveal"><b>Formül & Test</b><p>Stabilite, basınç ve püskürtme testleriyle formül son haline getiriliyor.</p></li>
      <li class="reveal"><b>Dolum & Ambalaj</b><p>Otomatik hatlarda dolum, gaz basma, ağırlık kontrolü ve etiketleme.</p></li>
      <li class="reveal"><b>Sevkiyat</b><p>ADR uyumlu depolama ve yurt içi / ihracat lojistiği bizden.</p></li>
    </ol>
  </div>
</section>

<!-- ======= CTA ======= -->
<section class="cta">
  <div class="container cta-inner">
    <h2>Projenizi konuşalım.</h2>
    <p>Fason üretim, private label veya formül geliştirme — ilk numune bizden.</p>
    <a href="/iletisim" class="btn btn-primary btn-lg">Teklif Alın</a>
  </div>
</section>

<%- include('../partials/footer') %>
